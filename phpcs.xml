<?xml version="1.0"?>
<!DOCTYPE xml>
<ruleset name="WordPress (WK Web Kreativ) Coding Standards">
	<description>A custom set of code standard rules to check for WK Web Kreativ WordPress coding standards.</description>

	<!-- Exclude the Composer Vendor directory. -->
	<exclude-pattern>*/vendor/*</exclude-pattern>

	<!-- Exclude the Node Modules directory. -->
	<exclude-pattern>*/node_modules/*</exclude-pattern>

	<!-- Exclude the build directory (auto-generated by @wordpress/scripts). -->
	<exclude-pattern>*/build/*</exclude-pattern>

	<!-- Exclude generated language files. -->
	<exclude-pattern>*.l10n.php*</exclude-pattern>

	<!-- Pass some flags to PHPCS:
		 p flag: Show progress of the run.
		 s flag: Show sniff codes in all reports.
	-->
	<arg value="ps"/>

	<!-- Only scan PHP files. -->
	<arg name="extensions" value="php" />

	<!-- Check up to 100 files simultanously. -->
	<arg name="parallel" value="100" />

	<rule ref="WordPress-Core">
		<!-- Ignore filenames. Without this exclusion file name like taxonomy-custom_taxonomy.php would not be allowed, since it contains underscore -->
		<exclude name="WordPress.Files.FileName" />

		<!-- Allow shorthand array syntax -->
		<exclude name="Generic.Arrays.DisallowShortArraySyntax.Found" />
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found" />

		<!-- Allow short ternary like ?: -->
		<exclude name="WordPress.PHP.DisallowShortTernary.Found" />
		<exclude name="Universal.Operators.DisallowShortTernary.Found" />

		<!-- Exclude Yoda conditions checks -->
		<exclude name="WordPress.PHP.YodaConditions" />

		<!-- Allow to skip the translator comment -->
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment" />
	</rule>

	<!-- Setting rules for alignment of array items -->
	<rule ref="WordPress.Arrays.MultipleStatementAlignment">
		<properties>
			<!-- No need to adjust alignment of large arrays when the item with the largest key is removed. -->
			<property name="exact" value="false"/>
		</properties>
	</rule>

	<!-- PHP version check. -->
	<config name="testVersion" value="8.4-"/>
</ruleset>
